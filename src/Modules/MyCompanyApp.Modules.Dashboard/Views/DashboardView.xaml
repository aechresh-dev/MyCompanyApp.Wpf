<UserControl x:Class="MyCompanyApp.Modules.Dashboard.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="LeftToRight"
             Background="#F8FAFC">
    <Grid Margin="24">
        <Border Background="White" CornerRadius="18" Padding="28">
            <StackPanel>
                <DockPanel Margin="0,0,0,18">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="{Binding Title}" FontSize="32" FontWeight="Bold" Foreground="#0F172A" />
                        <TextBlock Text="{Binding StatusMessage}" FontSize="15" Foreground="#64748B" Margin="0,8,0,0" />
                    </StackPanel>
                    <Button DockPanel.Dock="Right"
                            Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Width="130"
                            Height="42"
                            Background="#2563EB"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold" />
                </DockPanel>
                <UniformGrid Columns="3">
                    <Border Background="#EFF6FF" CornerRadius="16" Padding="18" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Users" FontSize="15" Foreground="#1D4ED8" />
                            <TextBlock Text="{Binding UsersCount}" FontSize="30" FontWeight="Bold" Foreground="#1E3A8A" />
                        </StackPanel>
                    </Border>
                    <Border Background="#ECFDF5" CornerRadius="16" Padding="18" Margin="6,0,6,0">
                        <StackPanel>
                            <TextBlock Text="Leave Requests" FontSize="15" Foreground="#047857" />
                            <TextBlock Text="{Binding LeaveRequestsCount}" FontSize="30" FontWeight="Bold" Foreground="#065F46" />
                        </StackPanel>
                    </Border>
                    <Border Background="#FFF7ED" CornerRadius="16" Padding="18" Margin="12,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Notifications" FontSize="15" Foreground="#C2410C" />
                            <TextBlock Text="{Binding NotificationsCount}" FontSize="30" FontWeight="Bold" Foreground="#9A3412" />
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>