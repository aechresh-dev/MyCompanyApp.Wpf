<Window x:Class="MyCompanyApp.Wpf.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ورود به سیستم"
        Height="430"
        Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft"
        Background="#F3F4F6">
    <Grid>
        <Border Width="390"
                Padding="28"
                Background="White"
                CornerRadius="18"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24"
                                  ShadowDepth="0"
                                  Opacity="0.18"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="MyCompanyApp"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#111827"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>

                <TextBlock Text="ورود به پنل مدیریت"
                           FontSize="14"
                           Foreground="#6B7280"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,28"/>

                <TextBlock Text="نام کاربری"
                           FontSize="13"
                           Foreground="#374151"
                           Margin="0,0,0,7"/>

                <TextBox x:Name="UsernameTextBox"
                         Height="42"
                         FontSize="15"
                         Padding="10,0"
                         VerticalContentAlignment="Center"
                         BorderBrush="#D1D5DB"
                         BorderThickness="1"
                         Text="admin"
                         Margin="0,0,0,16"/>

                <TextBlock Text="رمز عبور"
                           FontSize="13"
                           Foreground="#374151"
                           Margin="0,0,0,7"/>

                <PasswordBox x:Name="PasswordBox"
                             Height="42"
                             FontSize="15"
                             Padding="10,0"
                             VerticalContentAlignment="Center"
                             BorderBrush="#D1D5DB"
                             BorderThickness="1"
                             Password="admin123"
                             Margin="0,0,0,12"/>

                <TextBlock x:Name="ErrorTextBlock"
                           Text=""
                           Foreground="#DC2626"
                           FontSize="13"
                           TextWrapping="Wrap"
                           MinHeight="22"
                           Margin="0,0,0,12"/>

                <Button x:Name="LoginButton"
                        Content="ورود"
                        Height="44"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Background="#2563EB"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="LoginButton_Click"/>

                <TextBlock Text="حساب تست: admin / admin123"
                           FontSize="12"
                           Foreground="#9CA3AF"
                           HorizontalAlignment="Center"
                           Margin="0,18,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
