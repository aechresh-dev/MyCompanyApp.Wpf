<UserControl x:Class="MyCompanyApp.Wpf.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#F4F7FB">
        <Border Width="520"
                Padding="28"
                CornerRadius="18"
                Background="White"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24"
                                  ShadowDepth="4"
                                  Opacity="0.18" />
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="{Binding Title}"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#1F2937"
                           Margin="0,0,0,12" />

                <TextBlock Text="{Binding Description}"
                           FontSize="15"
                           Foreground="#6B7280"
                           TextWrapping="Wrap"
                           LineHeight="24" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
