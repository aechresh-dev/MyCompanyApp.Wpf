<UserControl x:Class="MyCompanyApp.Wpf.Views.LeaveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F9FAFB">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Leave"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="#111827"/>
            <TextBlock Text="Leave requests and approvals"
                       Margin="0,6,0,0"
                       FontSize="14"
                       Foreground="#6B7280"/>
        </StackPanel>

        <Border Grid.Row="2"
                Padding="24"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <TextBlock Text="Leave workflow"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#111827"/>
                <TextBlock Text="This module is ready for request forms, approval flow, and calendar integration."
                           Margin="0,10,0,0"
                           FontSize="14"
                           Foreground="#6B7280"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>