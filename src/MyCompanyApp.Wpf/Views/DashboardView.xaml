<UserControl x:Class="MyCompanyApp.Wpf.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F9FAFB">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Dashboard"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="#111827"/>
            <TextBlock Text="Company overview and operational summary"
                       Margin="0,6,0,0"
                       FontSize="14"
                       Foreground="#6B7280"/>
        </StackPanel>

        <UniformGrid Grid.Row="2"
                     Columns="3"
                     Rows="1">
            <Border Margin="0,0,16,0"
                    Padding="20"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Active Users"
                               FontSize="13"
                               Foreground="#6B7280"/>
                    <TextBlock Text="0"
                               Margin="0,10,0,0"
                               FontSize="32"
                               FontWeight="SemiBold"
                               Foreground="#111827"/>
                </StackPanel>
            </Border>

            <Border Margin="0,0,16,0"
                    Padding="20"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Leave Requests"
                               FontSize="13"
                               Foreground="#6B7280"/>
                    <TextBlock Text="0"
                               Margin="0,10,0,0"
                               FontSize="32"
                               FontWeight="SemiBold"
                               Foreground="#111827"/>
                </StackPanel>
            </Border>

            <Border Padding="20"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Modules"
                               FontSize="13"
                               Foreground="#6B7280"/>
                    <TextBlock Text="3"
                               Margin="0,10,0,0"
                               FontSize="32"
                               FontWeight="SemiBold"
                               Foreground="#111827"/>
                </StackPanel>
            </Border>
        </UniformGrid>
    </Grid>
</UserControl>